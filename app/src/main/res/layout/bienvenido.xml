<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Bienvenido">

  <!-- Logo -->
  <ImageView
      android:id="@+id/imageView"
      android:layout_width="172dp"
      android:layout_height="111dp"
      android:layout_marginTop="16dp"
      app:srcCompat="@drawable/icono_app"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- Titulo -->
  <TextView
      android:id="@+id/lbl_titulo"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="Bienvenido, Usuario"
      android:textColor="#E4582B"
      android:textSize="24sp"
      android:textStyle="bold"
      app:layout_constraintTop_toBottomOf="@+id/imageView"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- Imagen perfil -->
  <ImageView
      android:id="@+id/imgFotoPerfil"
      android:layout_width="157dp"
      android:layout_height="142dp"
      android:layout_marginTop="8dp"
      app:srcCompat="@mipmap/icono_usuario"
      app:layout_constraintTop_toBottomOf="@+id/lbl_titulo"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- ScrollView botones: entre imagen y btnCerrarSesion -->
  <ScrollView
      android:id="@+id/scrollBotones"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_marginStart="16dp"
      android:layout_marginEnd="16dp"
      android:layout_marginTop="8dp"
      android:layout_marginBottom="8dp"
      app:layout_constraintTop_toBottomOf="@+id/imgFotoPerfil"
      app:layout_constraintBottom_toTopOf="@+id/btnCerrarSesion"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

      <Button
          android:id="@+id/btnReiniciarSesion"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="REINICIAR SESION"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloUsuario"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO USUARIO"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloProducto"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO PRODUCTO"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloAcceso"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO ACCESO"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloPedido"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO PEDIDO"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloBitacora"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO BITACORA"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloCliente"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO CLIENTE"
          android:textColor="#000000"
          android:textStyle="bold" />

      <Button
          android:id="@+id/btnModuloGps"
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:layout_marginBottom="8dp"
          android:backgroundTint="#00C853"
          android:drawableEnd="@drawable/ic_menu"
          android:gravity="center"
          android:text="MODULO GPS"
          android:textColor="#000000"
          android:textStyle="bold" />
    </LinearLayout>
  </ScrollView>

  <!-- Cerrar Sesión fijo abajo -->
  <Button
      android:id="@+id/btnCerrarSesion"
      android:layout_width="0dp"
      android:layout_height="53dp"
      android:layout_marginStart="16dp"
      android:layout_marginEnd="16dp"
      android:layout_marginBottom="24dp"
      android:backgroundTint="#F44336"
      android:text="CERRAR SESIÓN"
      android:textColor="#FFFFFF"
      android:textStyle="bold"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>